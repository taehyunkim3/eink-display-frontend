DEVICE_AUTH_TOKEN="replace-with-a-long-random-token"

# Weather: Open-Meteo is used, so no API key is required.
WEATHER_LABEL="Seoul"
WEATHER_LATITUDE="37.5665"
WEATHER_LONGITUDE="126.9780"
WEATHER_TIMEZONE="Asia/Seoul"

# Google Calendar private iCal URLs. Keep these secret.
GOOGLE_CALENDAR_ICAL_URLS='["https://calendar.google.com/calendar/ical/.../basic.ics"]'

# Used for parsing iCal timestamps that do not include a timezone.
CALENDAR_TIMEZONE_OFFSET="+09:00"

# Market symbols. KRX uses Naver Finance, YAHOO uses Yahoo Finance.
STOCK_SYMBOLS="KRX:005930:삼성전자,KRX:000660:SK하이닉스,KRX:080220:제주반도체,KRX:347850:디앤디파마텍,KRX:011070:LG이노텍,YAHOO:CL=F:WTI 유가(달러)"

# E-ink refresh hint in seconds. Firmware can use this value for sleep interval.
DEVICE_REFRESH_SECONDS="1800"
